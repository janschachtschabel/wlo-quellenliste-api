{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/wc/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/example(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/wc/:path*", "destination": "/public/wc/:path*" },
    { "source": "/example.html", "destination": "/public/example.html" },
    { "source": "/example", "destination": "/public/example.html" },
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
